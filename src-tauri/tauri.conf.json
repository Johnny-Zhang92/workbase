{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/src/schema/stable.json",
  "productName": "DevTerm",
  "version": "0.1.0",
  "identifier": "com.devterm.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DevTerm",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZDMzYxNjA1MjA4NjE4RUEKUldUcUdJWWdCUlkyYko2aDJTUzZSWk5XWlFrc1hsNFVWZTN3cHUzbGxhVy8wMkpHQnpibzNCalMK",
      "endpoints": [
        "https://github.com/ZhangLiHua/devterm/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
